# Configuration Firebase (voir FIREBASE.md à la racine du dépôt).
# Copiez ce fichier en `.env.local` et remplissez les valeurs de votre projet.
# Tant que ce n'est pas fait, l'application fonctionne en mode local.
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
